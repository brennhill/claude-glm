#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
source "$SCRIPT_DIR/../scripts/lib/switchboard-config.sh"

usage() {
  switchboard_die "Usage: switchboard <tool> <provider> [args...]"
}

[[ $# -ge 2 ]] || usage

tool=$1
provider=$2
shift 2

case "$tool" in
  claude)
    source "$SCRIPT_DIR/../scripts/lib/tools/claude.sh"
    ;;
  codex)
    source "$SCRIPT_DIR/../scripts/lib/tools/codex.sh"
    ;;
  *)
    switchboard_die "Unsupported tool '$tool'. Supported tools: claude, codex"
    ;;
esac

case "$provider" in
  glm)
    source "$SCRIPT_DIR/../scripts/lib/providers/glm.sh"
    provider_glm_defaults
    ;;
  claude)
    source "$SCRIPT_DIR/../scripts/lib/providers/claude.sh"
    provider_claude_defaults
    ;;
  *)
    switchboard_die "Unsupported provider '$provider'. Supported providers: glm, claude"
    ;;
esac

if ! "tool_${tool}_supports_provider" "$provider"; then
  switchboard_die "Unsupported tool/provider pair: $tool -> $provider"
fi

binary=$("tool_${tool}_binary")
[[ -n "$binary" ]] || switchboard_die "Required tool binary '$tool' was not found in PATH"

switchboard_load_provider_config "$provider" || true
if ! switchboard_has_usable_token "$provider_config_auth_token"; then
  provider_config_auth_token=$(switchboard_prompt_for_token)
  switchboard_write_provider_config "$provider" "$provider_config_auth_token"
  printf 'Saved token to %s\n' "$provider_config_file" >&2
fi

"tool_${tool}_exec" "$binary" "$@"
